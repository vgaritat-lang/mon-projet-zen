# --- 3. MOTEUR DE CHARGEMENT ---
def afficher_fiche(categorie, nom_fichier):
    chemin = f"database/{categorie}/{nom_fichier}"
    if os.path.exists(chemin):
        try:
            # Nettoyage de la zone pour éviter le bloc rouge
            nom_unique = f"mod_{random.randint(0, 99999)}"
            spec = importlib.util.spec_from_file_location(nom_unique, chemin)
            mod = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)
            if hasattr(mod, 'afficher'):
                st.divider()
                mod.afficher()
        except Exception as e:
            st.error(f"Fiche indisponible : {e}")
    else:
        st.error(f"Fichier non trouvé : {chemin}")

