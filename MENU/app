# Moteur pour les fichiers .py (Leçons, Exos, Vocab)
def afficher_fiche(categorie, nom_fichier):
    # On cherche dans "database" comme dans votre structure
    chemin = f"database/{categorie}/{nom_fichier}"
    if os.path.exists(chemin):
        try:
            nom_unique = f"mod_{random.randint(0, 99999)}"
            spec = importlib.util.spec_from_file_location(nom_unique, chemin)
            mod = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)
            if hasattr(mod, 'afficher'):
                mod.afficher()
        except Exception as e:
            st.error(f"Fiche indisponible : {e}")
    else:
        st.error(f"Fichier non trouvé : {chemin}")

# Moteur pour les Mantras (JSON)
def moteur_mantras():
    try:
        with open('data/mantras.json', 'r', encoding='utf-8') as f:
            mantras = json.load(f)
        
        col1, col2 = st.columns([2, 1])
        with col2:
            if st.button("✨ Tirage Aléatoire"):
                st.session_state.selection_mantra = random.choice(mantras)
        
        with col1:
            titres = [m['titre'] for m in mantras]
            choix = st.selectbox("Parcourir le grimoire :", titres)
            for m in mantras:
                if m['titre'] == choix:
                    st.session_state.selection_mantra = m

        if "selection_mantra" in st.session_state:
            sel = st.session_state.selection_mantra
            st.divider()
            st.subheader(sel['titre'])
            st.markdown(sel['html_content'], unsafe_allow_html=True)
            
    except Exception as e:
        st.error("Le grimoire des mantras est fermé (Erreur JSON).")

# Moteur pour les Statistiques
def moteur_stats():
    user_email = st.session_state.get("email", "anonyme")
    path_sel = f"data/{user_email}/suivi_Fabrication_sel.json"
    if os.path.exists(path_sel):
        df = pd.DataFrame(json.load(open(path_sel, "r", encoding="utf-8")))
        st.subheader("📊 Vos Expériences")
        c1, c2 = st.columns(2)
        c1.metric("Opérations", len(df))
        c2.metric("Voie Cubique", len(df[df['forme_voie'].str.contains("Cubique")]))
        st.dataframe(df[['date', 'forme_voie', 'sel_origine']], use_container_width=True)
    else:
        st.info("Aucune donnée de laboratoire enregistrée.")

